# Supabase project URL, safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public API key, safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Last.fm API key for artist ingestion (cron/seed routes only)
LASTFM_API_KEY=

# Stripe secret key — SERVER ONLY. Use sk_test_… until live-mode switch (see LAUNCH_CHECKLIST.md)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for POST /api/webhooks/stripe (whsec_…)
STRIPE_WEBHOOK_SECRET=

# Public base URL of the deployed app (no trailing slash), e.g. https://melodymarkets.com
NEXT_PUBLIC_APP_URL=

# Shared secret for /api/cron/snapshot and /api/admin/seed (Authorization: Bearer …)
# Vercel Cron sends this automatically when set on the project.
CRON_SECRET=
