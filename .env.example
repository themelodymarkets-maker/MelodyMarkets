# Supabase project URL, safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public API key, safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key, server-only, bypasses row level security
SUPABASE_SERVICE_ROLE_KEY=

# Last.fm API key, used to fetch artist and track data
LASTFM_API_KEY=

# Stripe secret key, server-only, used to create charges/checkout sessions
STRIPE_SECRET_KEY=

# Stripe webhook signing secret, used to verify incoming Stripe webhook events
STRIPE_WEBHOOK_SECRET=

# Public base URL of the deployed app, used for redirects and webhooks
NEXT_PUBLIC_APP_URL=

# Shared secret used to authorize scheduled/cron job requests
CRON_SECRET=
